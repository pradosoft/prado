<%@ MasterClass="" %><!DOCTYPE html>
<html data-page="csp-test">
<head>
<meta charset="UTF-8">
<title>CSP Test – <%= $this->Action %></title>
<!-- Inline style: blocked by style-src without 'unsafe-inline' -->
<style id="inline-style">#style-marker { color: rgb(255, 0, 0); }</style>
</head>
<body>
<div id="action"><%= $this->Action %></div>

<!-- Inline script: blocked by script-src without 'unsafe-inline' or a matching nonce -->
<script id="inline-script">document.documentElement.dataset.inlineScriptRan = '1';</script>

<!-- Nonce-bearing script: allowed only when the CSP contains the matching nonce -->
<script id="nonce-script" nonce="<%= $this->Nonce %>">document.documentElement.dataset.nonceScriptRan = '1';</script>

<!-- External image from an untrusted domain: blocked by img-src 'self' -->
<img id="ext-img" src="https://img-src-blocked.csp-test.invalid/image.png" width="1" height="1">

<!-- iframe: blocked by frame-src 'none' (about:blank inherits parent CSP on some browsers) -->
<iframe id="test-frame" src="https://iframe-blocked.csp-test.invalid/" width="1" height="1"></iframe>

<!-- style-marker: red when inline-style ran, default colour when blocked -->
<div id="style-marker">styled</div>

<!-- Fetch test (runs via nonce script): blocked by connect-src 'none' -->
<script id="fetch-script" nonce="<%= $this->Nonce %>">
(function () {
  var el = document.getElementById('fetch-result');
  fetch('/tests/harness/HttpHeaders/index.php?page=Home&_ping=1')
    .then(function () { el.textContent = 'fetched'; })
    .catch(function () { el.textContent = 'blocked'; });
}());
</script>
<div id="fetch-result">pending</div>

<div id="ready">ready</div>
</body>
</html>

# Ignore generated content inside every harness web app.
# Each app (active-controls/, features/, etc.) has:
#   assets/             — compiled/published asset files
#   protected/runtime/  — framework cache files
#
# A .gitkeep file in each directory anchors it in git.

*/assets/**
!*/assets/.gitkeep

*/protected/runtime/**
!*/protected/runtime/.gitkeep

*/protected700/runtime/**
!*/protected700/runtime/.gitkeep

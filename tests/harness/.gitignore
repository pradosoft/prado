# Ignore generated content inside every harness web app.
# Most apps have the shape <app>/protected/runtime/ and <app>/assets/ — but
# some (e.g. HttpHeaders/web/protected/runtime/) embed an extra directory
# segment before `protected/`. The `**/` wildcard matches any number of
# segments so both layouts are covered:
#   tickets/protected/runtime/         ✓
#   HttpHeaders/web/protected/runtime/ ✓
#
# A .gitkeep file in each directory anchors it in git.

**/assets/**
!**/assets/.gitkeep

**/protected/runtime/**
!**/protected/runtime/.gitkeep

**/protected700/runtime/**
!**/protected700/runtime/.gitkeep

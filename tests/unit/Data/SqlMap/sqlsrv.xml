		<sqlMap resource="maps/mssql/Order.xml"/>
		<sqlMap resource="maps/mssql/Category.xml"/>
		<sqlMap resource="maps/mssql/Complex.xml"/>
		<sqlMap resource="maps/mssql/LineItem.xml"/>
		<sqlMap resource="maps/mssql/Enumeration.xml"/>
		<sqlMap resource="maps/mssql/Other.xml"/>
		<sqlMap resource="maps/mssql/ResultClass.xml"/>

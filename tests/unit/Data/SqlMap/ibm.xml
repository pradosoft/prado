	<sqlMaps>
		<sqlMap resource="maps/ibm/Account.xml"/>
		<sqlMap resource="maps/ibm/DynamicAccount.xml"/>
		<sqlMap resource="maps/ibm/Order.xml"/>
		<sqlMap resource="maps/ibm/Category.xml"/>
		<sqlMap resource="maps/ibm/Complex.xml"/>
		<sqlMap resource="maps/ibm/LineItem.xml"/>
		<sqlMap resource="maps/ibm/Enumeration.xml"/>
		<sqlMap resource="maps/ibm/Other.xml"/>
		<sqlMap resource="maps/ibm/ResultClass.xml"/>
		<sqlMap resource="maps/ibm/Document.xml"/>
		<sqlMap resource="maps/ibm/ActiveRecord.xml"/>
	</sqlMaps>

</sqlMapConfig>

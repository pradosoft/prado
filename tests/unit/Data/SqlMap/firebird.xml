		<sqlMap resource="maps/firebird/Category.xml"/>
		<sqlMap resource="maps/firebird/Complex.xml"/>
		<sqlMap resource="maps/firebird/LineItem.xml"/>
		<sqlMap resource="maps/firebird/Enumeration.xml"/>
		<sqlMap resource="maps/firebird/Other.xml"/>
		<sqlMap resource="maps/firebird/ResultClass.xml"/>

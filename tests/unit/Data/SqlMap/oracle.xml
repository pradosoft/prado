	<sqlMaps>
		<sqlMap resource="maps/oracle/Account.xml"/>
		<sqlMap resource="maps/oracle/DynamicAccount.xml"/>
		<sqlMap resource="maps/oracle/Order.xml"/>
		<sqlMap resource="maps/oracle/Category.xml"/>
		<sqlMap resource="maps/oracle/Complex.xml"/>
		<sqlMap resource="maps/oracle/LineItem.xml"/>
		<sqlMap resource="maps/oracle/Enumeration.xml"/>
		<sqlMap resource="maps/oracle/Other.xml"/>
		<sqlMap resource="maps/oracle/ResultClass.xml"/>
		<sqlMap resource="maps/oracle/Document.xml"/>
		<sqlMap resource="maps/oracle/ActiveRecord.xml"/>
	</sqlMaps>

</sqlMapConfig>

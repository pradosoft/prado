<?xml version="1.0" encoding="utf-8"?>
<sqlMapConfig>

	<properties>
		<property name="selectKey" value="SELECT categories_seq.CURRVAL AS value FROM DUAL" />
		<property name="MyCategoryName" value="'Film'" />
		<property name="accountName" value="'Joe'" />
